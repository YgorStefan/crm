# ============================================================
# public/.htaccess — Roteamento via mod_rewrite
# ============================================================
# Redireciona TODAS as requisições para public/index.php,
# exceto arquivos e diretórios que realmente existem (assets,
# imagens, etc.), permitindo que o Router PHP processe a URL.
# ============================================================

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Se a requisição for para um arquivo ou diretório que EXISTE fisicamente,
    # serve diretamente (ex.: /public/assets/css/app.css, /public/uploads/foto.jpg)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Caso contrário, encaminha tudo para o front controller
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Cabeçalhos de segurança HTTP
<IfModule mod_headers.c>
    # Previne que o browser "adivinhe" o tipo de conteúdo (MIME sniffing)
    Header set X-Content-Type-Options "nosniff"
    # Ativa proteção XSS do browser (legado, ainda útil em browsers antigos)
    Header set X-XSS-Protection "1; mode=block"
    # Impede que o site seja carregado em iframes (clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
