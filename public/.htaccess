# ============================================================
# public/.htaccess — Roteamento via mod_rewrite
# ============================================================
# Redireciona TODAS as requisições para public/index.php,
# exceto arquivos e diretórios que realmente existem (assets,
# imagens, etc.), permitindo que o Router PHP processe a URL.
# ============================================================

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Força HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Se a requisição for para um arquivo ou diretório que EXISTE fisicamente,
    # serve diretamente (ex.: /public/assets/css/app.css, /public/uploads/foto.jpg)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Caso contrário, encaminha tudo para o front controller
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Cabeçalhos de segurança HTTP
<IfModule mod_headers.c>
    # Strict-Transport-Security (HSTS) — SEC-01
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Impede carregamento em iframes (clickjacking) — SEC-01
    Header set X-Frame-Options "DENY"

    # Previne MIME sniffing
    Header set X-Content-Type-Options "nosniff"

    # Controla Referer em navegação cross-origin
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Desabilita APIs sensíveis não utilizadas
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
