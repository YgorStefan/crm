# ============================================================
# .gitignore — CRM Empresarial
# ============================================================
# Lista de arquivos e pastas que NÃO devem ir para o repositório.
# Principalmente: credenciais, uploads de usuários e caches.
# ============================================================

# Arquivos .env com variáveis de ambiente reais
.env
.env.local
.env.*.local
.env.production
.env.staging

# --- Uploads de usuários ---
# Arquivos enviados pelos usuários (avatares, anexos).
# Apenas a pasta deve existir (mantemos o .gitkeep).
public/uploads/*
!public/uploads/.gitkeep

# --- Cache e sessões PHP ---
/tmp/
*.cache

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs e editores ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Logs ---
*.log
error_log

# --- Claude Code e planejamento GSD ---
.claude/
.planning/
CLAUDE.md

# --- Scripts de Infra ---
deploy.sh

# --- Tailwind CLI binary (downloaded via scripts/setup_tailwind.php) ---
.bin/

# --- Configurações de Servidor PHP ---
public/.user.ini
.user.ini

# --- Credenciais de produção ---
env\ crm.txt

# --- Config de banco (credenciais reais ficam no .env) ---
config/database.php

# --- Scripts descartáveis de uso único ---
# (scripts de produção ficam em database/migrations/ e bin/)

# --- Tailwind source e config (versionados) ---
# tailwind.config.js e resources/ foram removidos do ignore

# --- Logs gerados em runtime ---
storage/

# docs/superpowers/ removido do ignore — specs e planos são versionados
