# ============================================================
# CRM Empresarial — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA commite o arquivo .env em repositórios públicos!
# ============================================================

# --- Banco de Dados ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_db
DB_USER=root
DB_PASS=sua_senha_aqui
DB_CHARSET=utf8mb4

# --- Aplicação ---
APP_NAME="CRM Empresarial"
APP_URL=http://localhost/crm/public
APP_ENV=development   # development | production
APP_DEBUG=true        # false em produção
APP_TIMEZONE=America/Sao_Paulo

# --- Sessão ---
SESSION_NAME=crm_session
SESSION_LIFETIME=7200  # segundos (2 horas)
